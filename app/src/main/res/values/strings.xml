    <string name="privacy_data_screen_title">Privacy &amp; data</string>
    <string name="privacy_data_intro">Use this screen to permanently erase your business data from this device and, when you are signed in, remove your cloud sign-in and mirrored cloud copies created by HisabKitab Pro.</string>
    <string name="privacy_data_what_removed_title">What will be removed</string>
    <string name="privacy_data_bullet_local">Local encrypted database: customers, suppliers, bills, transactions, reminders, staff, inventory, visiting card drafts, and settings stored in the app.</string>
    <string name="privacy_data_bullet_files">Temporary exports and previews in app cache (for example visiting-card PDFs/PNGs and WhatsApp reminder images).</string>
    <string name="privacy_data_bullet_prefs">App preference files on this device (automation toggles, filters, offline assistant queue, sync retry counters).</string>
    <string name="privacy_data_bullet_drive">If you used Cloud Backup to Google Drive, backup files in your Google account are not removed automatically — manage them in Google Drive if needed.</string>
    <string name="privacy_data_bullet_cloud">When signed in: mirrored Shared Khata documents in Firebase for this device business id, then your Firebase Authentication user.</string>
    <string name="privacy_data_bullet_locale">Your chosen display language is kept so the app stays usable after a reset.</string>
    <string name="privacy_data_warning">This cannot be undone. Export anything you must keep before continuing.</string>
    <string name="privacy_data_type_delete_label">Type DELETE to confirm you understand this is permanent</string>
    <string name="privacy_data_signed_out_note">You are not signed in to a cloud account. You can still erase all local data on this device.</string>
