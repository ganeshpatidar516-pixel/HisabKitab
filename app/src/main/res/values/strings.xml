    <string name="permission_camera_title">Camera Permission</string>
    <string name="permission_camera_body">HisabKitab Pro uses the camera to scan QR codes for payments, scan barcodes for inventory, scan paper bills with OCR, and capture your business QR for the profile. The camera turns on only when you open one of these screens. No images are uploaded; everything is processed on this device.</string>
    <string name="permission_microphone_title">Microphone Permission</string>
    <string name="permission_microphone_body">Voice command needs microphone access to convert your speech into text for assistant commands. Audio is used only for this feature when you tap the mic. No audio is uploaded; speech is processed on this device.</string>
    <string name="permission_contacts_title">Contacts Permission</string>
    <string name="permission_contacts_body">Import from Contacts needs permission to read contact name and phone number. This is used only when you choose Import from Contacts. No contact data leaves the device automatically.</string>

