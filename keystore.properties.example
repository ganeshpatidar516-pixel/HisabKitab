# Copy to keystore.properties (gitignored) for Play Store release signing.
# storeFile path is relative to the project root.
#
# storeFile=release/hisabkitab-upload.jks
# storePassword=your_password   (escape # as \# in Java properties)
# keyAlias=upload
# keyPassword=your_password
# Save as UTF-8 without BOM (PowerShell Set-Content -Encoding utf8 adds BOM and breaks storeFile).
